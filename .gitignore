# =============================================================================
# .gitignore — MT4/MT5 Trading Dashboard
# =============================================================================

# ── Environment & Secrets (NEVER upload these) ────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.env

# ── Python Virtual Environments ───────────────────────────────────────────────
venv/
.venv/
env/
ENV/
venv.bak/

# ── Python Cache & Compiled Files ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ── Database Files (local only — use Supabase in production) ─────────────────
*.db
*.sqlite
*.sqlite3
trading_dashboard.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ── Build & Distribution ──────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── IDE & Editor Files ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Alembic (keep folder, ignore generated files) ────────────────────────────
alembic/versions/*.pyc

# ── Upload & Media Files ──────────────────────────────────────────────────────
uploads/
media/

# ── Temporary Files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup

# ── Node (if any frontend tools added later) ─────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log

# ── Diagnostic / test scripts (optional — remove if you want to keep them) ───
test_login.py
create_admin.py
